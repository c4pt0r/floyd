+        int proposal_count,
+        int output_ids[6],
+        float output_confidence[5]) {
+    enum { DSPARK_MAX_STAGE_TOKENS = 5, DSPARK_NOISE = 128799 };
+    if (!g || !g->dspark_enabled || !support_model || !dspark ||
+        !output_ids || !output_confidence || proposal_count < 2 ||
+        proposal_count > 6 ||
+        g->dspark_position == 0) return false;
+    const int stage_tokens = proposal_count - 1;
+
+    int draft_ids[DSPARK_MAX_STAGE_TOKENS] = {
+        input_token, DSPARK_NOISE, DSPARK_NOISE, DSPARK_NOISE, DSPARK_NOISE,
+    };
+    token_vec draft = {
+        .v = draft_ids,
+        .len = stage_tokens,
+        .cap = DSPARK_MAX_STAGE_TOKENS,
+    };
+    bool ok = metal_graph_upload_prompt_tokens(g->prefill_tokens,
+                                                &draft,
+                                                0,
+                                                (uint32_t)stage_tokens);
+    if (ok) ok = metal_graph_upload_prompt_embeddings_hc(
+            g->batch_cur_hc,
+            g->prefill_tokens,
+            base_model,
+            base_weights,
+            &draft,
+            0,
+            (uint32_t)stage_tokens);
+
+    ds4_gpu_tensor *saved_cache = g->layer_raw_cache[0];
+    const uint32_t saved_raw_cap = g->raw_cap;
+    const uint32_t saved_raw_window = g->raw_window;
+    const bool saved_skip_quant = g->skip_raw_kv_quant;
+    const bool saved_full_block = g->dspark_full_block_attention;
+    g->raw_cap = DS4_N_SWA;
+    g->raw_window = DS4_N_SWA;
+    g->skip_raw_kv_quant = true;
+    g->dspark_full_block_attention = true;
+
+    ds4_gpu_tensor *draft_hidden = ds4_gpu_tensor_view(
+            g->batch_ffn_cur, 0,
+            (uint64_t)stage_tokens * DS4_N_EMBD * sizeof(float));
+    ds4_gpu_tensor *confidence_hidden = ds4_gpu_tensor_view(
+            g->batch_router_probs, 0,
+            (uint64_t)stage_tokens * sizeof(float));
+    if (!draft_hidden || !confidence_hidden) ok = false;
+
+    if (ok) ok = ds4_gpu_begin_commands() != 0;
+    for (uint32_t stage = 0; ok && stage < 3; stage++) {
+        g->layer_raw_cache[0] = g->dspark_raw_cache[stage];
+        ok = metal_graph_encode_layer_batch(g,
+                                             support_model,
+                                             &dspark->stage[stage],
+                                             0,
+                                             g->dspark_position,
+                                             (uint32_t)stage_tokens);
+    }
+    if (ok) ok = metal_graph_encode_dspark_head_batch(g,
+                                                       base_model,
+                                                       base_weights,
+                                                       support_model,
+                                                       dspark,
+                                                       (uint32_t)stage_tokens);
+    if (ok) ok = ds4_gpu_matmul_f32_tensor(
+            confidence_hidden,
+            support_model->map,
+            support_model->size,
+            dspark->confidence_proj->abs_offset,
+            DS4_N_EMBD,
+            1,
+            draft_hidden,
+            (uint32_t)stage_tokens) != 0;
+    if (ok) ok = ds4_gpu_end_commands() != 0;
+    else (void)ds4_gpu_synchronize();
+
+    output_ids[0] = input_token;
+    ds4_gpu_tensor *selected_ids = ds4_gpu_tensor_view(
+            g->batch_router_selected, 0,
+            (uint64_t)stage_tokens * sizeof(int32_t));
+    if (!selected_ids) ok = false;
+    if (ok) ok = ds4_gpu_begin_commands() != 0;
+    for (int position = 0; ok && position < stage_tokens; position++) {
+        ds4_gpu_tensor *row_logits = ds4_gpu_tensor_view(
+                g->spec_logits,
+                (uint64_t)position * DS4_N_VOCAB * sizeof(float),
+                (uint64_t)DS4_N_VOCAB * sizeof(float));
+        ds4_gpu_tensor *hidden_score = ds4_gpu_tensor_view(
+                confidence_hidden,
+                (uint64_t)position * sizeof(float),
+                sizeof(float));
+        ds4_gpu_tensor *markov_score = ds4_gpu_tensor_view(
+                g->batch_router_weights,
+                (uint64_t)position * sizeof(float),
+                sizeof(float));
+        ds4_gpu_tensor *selected_id = ds4_gpu_tensor_view(
+                selected_ids,
+                (uint64_t)position * sizeof(int32_t),
+                sizeof(int32_t));
+        ds4_gpu_tensor *previous_id = position > 0
+            ? ds4_gpu_tensor_view(
+                selected_ids,
+                (uint64_t)(position - 1) * sizeof(int32_t),
+                sizeof(int32_t))
+            : NULL;
+        ok = row_logits && hidden_score && markov_score && selected_id &&
+             (position == 0 || previous_id);
+        if (ok && position == 0) {
+            ok = ds4_gpu_embed_token_hc_tensor(
+                    g->mtp_embed,
+                    support_model->map,
+                    support_model->size,
+                    dspark->markov_w1->abs_offset,
+                    (uint32_t)dspark->markov_w1->dim[1],
+                    (uint32_t)input_token,
+                    256,
+                    1) != 0;
+        } else if (ok) {
+            ok = ds4_gpu_embed_tokens_hc_tensor(
+                    g->mtp_embed,
+                    previous_id,
+                    support_model->map,
+                    support_model->size,
+                    dspark->markov_w1->abs_offset,
+                    (uint32_t)dspark->markov_w1->dim[1],
+                    1,
+                    256,
+                    1) != 0;
+        }
+        if (ok) ok = ds4_gpu_matmul_q8_0_tensor(
+                g->logits,
+                support_model->map,
+                support_model->size,
+                dspark->markov_w2->abs_offset,
+                256,
+                DS4_N_VOCAB,
+                g->mtp_embed,
+                1) != 0;
+        if (ok) ok = ds4_gpu_add_tensor(row_logits,
+                                         row_logits,
+                                         g->logits,
+                                         DS4_N_VOCAB) != 0;
+        if (ok) ok = ds4_gpu_argmax_tensor(selected_id,
+                                            row_logits,
+                                            DS4_N_VOCAB) != 0;
+        if (ok) ok = ds4_gpu_matmul_f32_tensor(
+                markov_score,
+                support_model->map,
+                support_model->size,
+                dspark->confidence_proj->abs_offset +
+                    (uint64_t)DS4_N_EMBD * sizeof(float),
+                256,
+                1,
+                g->mtp_embed,
+                1) != 0;
+        if (ok) ok = ds4_gpu_add_tensor(markov_score,
+                                         hidden_score,
+                                         markov_score,
+                                         1) != 0;
+        ds4_gpu_tensor_free(previous_id);
+        ds4_gpu_tensor_free(selected_id);
+        ds4_gpu_tensor_free(markov_score);
+        ds4_gpu_tensor_free(hidden_score);
+        ds4_gpu_tensor_free(row_logits);
+    }
+    if (ok) ok = ds4_gpu_end_commands() != 0;
+    else (void)ds4_gpu_synchronize();
+    if (ok) ok = ds4_gpu_tensor_read(
+            selected_ids, 0, output_ids + 1,
+            (uint64_t)stage_tokens * sizeof(output_ids[0])) != 0;
+    if (ok) ok = ds4_gpu_tensor_read(
+            g->batch_router_weights, 0, output_confidence,
+            (uint64_t)stage_tokens * sizeof(output_confidence[0])) != 0;
+
+    ds4_gpu_tensor_free(selected_ids);
+    ds4_gpu_tensor_free(confidence_hidden);
+    ds4_gpu_tensor_free(draft_hidden);
+
+    g->layer_raw_cache[0] = saved_cache;
+    g->raw_cap = saved_raw_cap;
+    g->raw_window = saved_raw_window;
+    g->skip_raw_kv_quant = saved_skip_quant;
+    g->dspark_full_block_attention = saved_full_block;
+    return ok;
+}
