+static bool metal_graph_alloc_dspark_state(
+        ds4_gpu_graph *g,
+        const ds4_model *model,
+        const ds4_dspark_weights *weights) {
+    if (!g || !model || !weights || g->prefill_cap == 0) return false;
+    g->dspark_main_hidden = ds4_gpu_tensor_alloc(
+            (uint64_t)g->prefill_cap * 3u * DS4_N_EMBD * sizeof(float));
+    g->dspark_main_x = ds4_gpu_tensor_alloc(
+            (uint64_t)g->prefill_cap * DS4_N_EMBD * sizeof(float));
+    bool ok = g->dspark_main_hidden && g->dspark_main_x;
+    for (uint32_t stage = 0; ok && stage < 3; stage++) {
+        g->dspark_raw_cache[stage] = ds4_gpu_tensor_alloc(
+                (uint64_t)DS4_N_SWA * DS4_N_HEAD_DIM * sizeof(float));
+        ok = g->dspark_raw_cache[stage] != NULL;
+    }
+    if (!ok) return false;
+    g->dspark_model = model;
+    g->dspark_weights = weights;
+    g->dspark_position = 0;
+    g->dspark_enabled = true;
+    return true;
+}
