+static bool metal_graph_encode_dspark_append_main(
+        ds4_gpu_graph *g,
+        uint32_t start,
+        uint32_t n_tokens) {
+    if (!g->dspark_enabled) return true;
+    if (!g->dspark_model || !g->dspark_weights || n_tokens == 0 ||
+        n_tokens > g->prefill_cap) return false;
+
+    uint32_t skip = 0;
+    if (n_tokens > DS4_N_SWA) {
+        skip = n_tokens - DS4_N_SWA;
+        start += skip;
+        n_tokens = DS4_N_SWA;
+    }
+    const uint64_t main_width = 3ull * DS4_N_EMBD;
+    ds4_gpu_tensor *main_hidden = ds4_gpu_tensor_view(
+            g->dspark_main_hidden,
+            (uint64_t)skip * main_width * sizeof(float),
+            (uint64_t)n_tokens * main_width * sizeof(float));
+    ds4_gpu_tensor *main_x = ds4_gpu_tensor_view(
+            g->dspark_main_x,
+            0,
+            (uint64_t)n_tokens * DS4_N_EMBD * sizeof(float));
+    bool ok = main_hidden && main_x;
+    if (ok) ok = metal_graph_matmul_plain_tensor(
+            g->batch_ffn_cur,
+            g->dspark_model,
+            g->dspark_weights->main_proj,
+            main_width,
+            DS4_N_EMBD,
+            main_hidden,
+            n_tokens);
+    if (ok) ok = ds4_gpu_rms_norm_weight_rows_tensor(
+            main_x,
+            g->batch_ffn_cur,
+            g->dspark_model->map,
+            g->dspark_model->size,
+            g->dspark_weights->main_norm->abs_offset,
+            DS4_N_EMBD,
+            n_tokens,
+            DS4_RMS_EPS) != 0;
+    if (ok) {
+        metal_graph_debug_dump_tensor("dspark_main_x",
+                                      main_x,
+                                      (uint64_t)n_tokens * DS4_N_EMBD,
+                                      0,
+                                      start);
+    }
+
+    const float freq_base = layer_rope_freq_base(0);
+    const float freq_scale = layer_rope_freq_scale(0);
+    for (uint32_t stage = 0; ok && stage < 3; stage++) {
+        const ds4_layer_weights *layer = &g->dspark_weights->stage[stage];
+        ok = metal_graph_matmul_plain_tensor(g->batch_kv_raw,
+                                             g->dspark_model,
+                                             layer->attn_kv,
+                                             DS4_N_EMBD,
+                                             DS4_N_HEAD_DIM,
+                                             main_x,
+                                             n_tokens);
+        if (ok) ok = ds4_gpu_rms_norm_weight_rows_tensor(
+                g->batch_kv,
+                g->batch_kv_raw,
+                g->dspark_model->map,
+                g->dspark_model->size,
+                layer->attn_kv_a_norm->abs_offset,
+                DS4_N_HEAD_DIM,
+                n_tokens,
+                DS4_RMS_EPS) != 0;
+        if (ok) ok = ds4_gpu_rope_tail_tensor(g->batch_kv,
+                                               n_tokens,
+                                               DS4_N_HEAD_KV,
+                                               DS4_N_HEAD_DIM,
+                                               DS4_N_ROT,
+                                               start,
+                                               0,
+                                               false,
+                                               freq_base,
+                                               freq_scale,
+                                               0.0f,
+                                               1.0f,
+                                               DS4_ROPE_YARN_BETA_FAST,
+                                               DS4_ROPE_YARN_BETA_SLOW) != 0;
+        if (ok) {
+            metal_graph_debug_dump_tensor("dspark_main_kv",
+                                          g->batch_kv,
+                                          (uint64_t)n_tokens * DS4_N_HEAD_DIM,
+                                          stage,
+                                          start);
+        }
+        if (ok) ok = metal_graph_dspark_copy_ring(
+                g->dspark_raw_cache[stage], g->batch_kv, start, n_tokens);
+    }
+    if (ok) g->dspark_position = start + n_tokens;
+    ds4_gpu_tensor_free(main_x);
+    ds4_gpu_tensor_free(main_hidden);
+    return ok;
+}
