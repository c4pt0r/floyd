+int ds4_gpu_hc_mean_stage_tensor(
+        ds4_gpu_tensor       *out,
+        const ds4_gpu_tensor *residual_hc,
+        uint32_t                n_embd,
+        uint32_t                n_hc,
+        uint32_t                n_stages,
+        uint32_t                stage,
+        uint32_t                n_tokens) {
+    if (!g_initialized && !ds4_gpu_init()) return 0;
+    if (!out || !residual_hc || n_embd == 0 || n_hc == 0 ||
+        n_stages == 0 || stage >= n_stages || n_tokens == 0) return 0;
+
+    @autoreleasepool {
+        id<MTLBuffer> xbuf = ds4_gpu_tensor_buffer(residual_hc);
+        id<MTLBuffer> outbuf = ds4_gpu_tensor_buffer(out);
+        const uint64_t input_values = (uint64_t)n_tokens * n_hc * n_embd;
+        const uint64_t output_values = (uint64_t)n_tokens * n_stages * n_embd;
+        if (!xbuf || !outbuf ||
+            ds4_gpu_tensor_bytes(residual_hc) < input_values * sizeof(float) ||
+            ds4_gpu_tensor_bytes(out) < output_values * sizeof(float)) return 0;
+
+        id<MTLComputePipelineState> pipeline =
+            ds4_gpu_hot_pipeline(ds4_gpu_get_pipeline("kernel_dsv4_hc_mean_stage"),
+                                 "kernel_dsv4_hc_mean_stage");
+        if (!pipeline) return 0;
+        ds4_gpu_hc_mean_stage_args args = {
+            .n_embd = n_embd,
+            .n_hc = n_hc,
+            .n_stages = n_stages,
+            .stage = stage,
+            .n_tokens = n_tokens,
+        };
+        const NSUInteger n_elem = (NSUInteger)n_tokens * n_embd;
+        const NSUInteger nth = MIN((NSUInteger)256, n_elem);
+        int owned = 0;
+        id<MTLCommandBuffer> cb = ds4_gpu_command_buffer(&owned);
+        if (!cb) return 0;
+        id<MTLComputeCommandEncoder> enc = ds4_gpu_compute_encoder(cb);
+        [enc setComputePipelineState:pipeline];
+        [enc setBytes:&args length:sizeof(args) atIndex:0];
+        [enc setBuffer:xbuf offset:ds4_gpu_tensor_offset(residual_hc) atIndex:1];
+        [enc setBuffer:outbuf offset:ds4_gpu_tensor_offset(out) atIndex:2];
+        [enc dispatchThreads:MTLSizeMake(n_elem, 1, 1)
+              threadsPerThreadgroup:MTLSizeMake(nth, 1, 1)];
+        ds4_gpu_end_compute_encoder(cb, enc);
+        if (!ds4_gpu_finish_command_buffer(cb, owned, "HC mean stage")) return 0;
+    }
+    return 1;
+}
