+static bool metal_graph_eval_dspark_proposals(
+        ds4_gpu_graph *g,
+        const ds4_model *base_model,
+        const ds4_weights *base_weights,
+        const ds4_model *support_model,
+        const ds4_dspark_weights *dspark,
+        int input_token,
+        int output_ids[6]) {
+    enum { DSPARK_DRAFT = 5, DSPARK_NOISE = 128799 };
+    if (!g || !g->dspark_enabled || !support_model || !dspark ||
+        !output_ids || g->dspark_position == 0) return false;
+
+    int draft_ids[DSPARK_DRAFT] = {
+        input_token, DSPARK_NOISE, DSPARK_NOISE, DSPARK_NOISE, DSPARK_NOISE,
+    };
+    token_vec draft = {.v = draft_ids, .len = DSPARK_DRAFT, .cap = DSPARK_DRAFT};
+    bool ok = metal_graph_upload_prompt_tokens(g->prefill_tokens,
+                                                &draft,
+                                                0,
+                                                DSPARK_DRAFT);
+    if (ok) ok = metal_graph_upload_prompt_embeddings_hc(
+            g->batch_cur_hc,
+            g->prefill_tokens,
+            base_model,
+            base_weights,
+            &draft,
+            0,
+            DSPARK_DRAFT);
+
+    ds4_gpu_tensor *saved_cache = g->layer_raw_cache[0];
+    const uint32_t saved_raw_cap = g->raw_cap;
+    const uint32_t saved_raw_window = g->raw_window;
+    const bool saved_skip_quant = g->skip_raw_kv_quant;
+    const bool saved_full_block = g->dspark_full_block_attention;
+    g->raw_cap = DS4_N_SWA;
+    g->raw_window = DS4_N_SWA;
+    g->skip_raw_kv_quant = true;
+    g->dspark_full_block_attention = true;
+
+    if (ok) ok = ds4_gpu_begin_commands() != 0;
+    for (uint32_t stage = 0; ok && stage < 3; stage++) {
+        g->layer_raw_cache[0] = g->dspark_raw_cache[stage];
+        ok = metal_graph_encode_layer_batch(g,
+                                             support_model,
+                                             &dspark->stage[stage],
+                                             0,
+                                             g->dspark_position,
+                                             DSPARK_DRAFT);
+    }
+    if (ok) ok = metal_graph_encode_dspark_head_batch(g,
+                                                       base_model,
+                                                       base_weights,
+                                                       support_model,
+                                                       dspark,
+                                                       DSPARK_DRAFT);
+    if (ok) ok = ds4_gpu_end_commands() != 0;
+    else (void)ds4_gpu_synchronize();
+
+    output_ids[0] = input_token;
+    for (int position = 0; ok && position < DSPARK_DRAFT; position++) {
+        ds4_gpu_tensor *row_logits = ds4_gpu_tensor_view(
+                g->spec_logits,
+                (uint64_t)position * DS4_N_VOCAB * sizeof(float),
+                (uint64_t)DS4_N_VOCAB * sizeof(float));
+        ok = row_logits != NULL;
+        if (ok) ok = ds4_gpu_begin_commands() != 0;
+        if (ok) ok = ds4_gpu_embed_token_hc_tensor(
+                g->mtp_embed,
+                support_model->map,
+                support_model->size,
+                dspark->markov_w1->abs_offset,
+                (uint32_t)dspark->markov_w1->dim[1],
+                (uint32_t)output_ids[position],
+                256,
+                1) != 0;
+        if (ok) ok = ds4_gpu_matmul_q8_0_tensor(
+                g->logits,
+                support_model->map,
+                support_model->size,
+                dspark->markov_w2->abs_offset,
+                256,
+                DS4_N_VOCAB,
+                g->mtp_embed,
+                1) != 0;
+        if (ok) ok = ds4_gpu_add_tensor(row_logits,
+                                         row_logits,
+                                         g->logits,
+                                         DS4_N_VOCAB) != 0;
+        if (ok) ok = ds4_gpu_argmax_tensor(g->comp_selected,
+                                            row_logits,
+                                            DS4_N_VOCAB) != 0;
+        if (ok) ok = ds4_gpu_end_commands() != 0;
+        else (void)ds4_gpu_synchronize();
+        if (ok) ok = ds4_gpu_tensor_read(g->comp_selected,
+                                          0,
+                                          &output_ids[position + 1],
+                                          sizeof(output_ids[position + 1])) != 0;
+        ds4_gpu_tensor_free(row_logits);
+    }
+
+    g->layer_raw_cache[0] = saved_cache;
+    g->raw_cap = saved_raw_cap;
+    g->raw_window = saved_raw_window;
+    g->skip_raw_kv_quant = saved_skip_quant;
+    g->dspark_full_block_attention = saved_full_block;
+    return ok;
+}
+
+int ds4_dspark_probe_stages(const char *base_path, const char *support_path,
+                            const float *prefill_kv, unsigned prefill_count,
+                            const float *current_main_x, int input_token,
+                            float *stage_outputs, int *output_ids) {
+    enum { DSPARK_STAGES = 3, DSPARK_DRAFT = 5, DSPARK_NOISE = 128799 };
+    if (!base_path || !support_path || !prefill_kv || !current_main_x ||
+        !stage_outputs || !output_ids || prefill_count == 0 ||
+        prefill_count + DSPARK_DRAFT > DS4_N_SWA)
+        return 1;
+
+    ds4_model base_model, support_model;
+    memset(&base_model, 0, sizeof(base_model));
+    memset(&support_model, 0, sizeof(support_model));
+    base_model.fd = support_model.fd = -1;
+    ds4_weights base_weights;
+    ds4_dspark_weights dspark;
+    ds4_gpu_graph graph;
+    memset(&graph, 0, sizeof(graph));
+    ds4_gpu_tensor *stage_cache[DSPARK_STAGES] = {0};
+    bool graph_ready = false;
+    bool ok = true;
+
+    model_open(&base_model, base_path, true, true);
+    config_validate_model(&base_model);
+    weights_bind(&base_weights, &base_model, false, 0, 0, true, false);
+    model_open(&support_model, support_path, true, true);
+    dspark_weights_bind(&dspark, &support_model);
+
+    ok = ds4_gpu_init() != 0;
+    if (ok) ok = ds4_gpu_set_model_fd_for_map(base_model.fd, base_model.map) != 0;
+    if (ok) ok = ds4_gpu_set_model_map_range(base_model.map, base_model.size,
+                                               base_model.tensor_data_pos,
+                                               base_model.size - base_model.tensor_data_pos,
+                                               base_model.max_tensor_bytes) != 0;
+    if (ok) ok = ds4_gpu_set_model_map_range(support_model.map, support_model.size,
+                                               support_model.tensor_data_pos,
+                                               support_model.size - support_model.tensor_data_pos,
+                                               support_model.max_tensor_bytes) != 0;
+    if (ok) {
+        ok = metal_graph_alloc_raw_cap(&graph, &base_weights, &base_weights.layer[0],
+                                       DS4_N_SWA, DS4_N_SWA, 16, true);
+        graph_ready = ok;
+        graph.skip_raw_kv_quant = true;
+        graph.dspark_full_block_attention = true;
+    }
+    for (int stage = 0; ok && stage < DSPARK_STAGES; stage++) {
+        stage_cache[stage] = ds4_gpu_tensor_alloc(
+                (uint64_t)DS4_N_SWA * DS4_N_HEAD_DIM * sizeof(float));
+        ok = stage_cache[stage] != NULL;
+        if (ok) {
+            ok = ds4_gpu_tensor_write(stage_cache[stage], 0,
+                                      prefill_kv + (uint64_t)stage * prefill_count * DS4_N_HEAD_DIM,
+                                      (uint64_t)prefill_count * DS4_N_HEAD_DIM * sizeof(float)) != 0;
+        }
+    }
+
+    int draft_ids[DSPARK_DRAFT] = {
+        input_token, DSPARK_NOISE, DSPARK_NOISE, DSPARK_NOISE, DSPARK_NOISE,
+    };
+    token_vec draft = {.v = draft_ids, .len = DSPARK_DRAFT, .cap = DSPARK_DRAFT};
+    if (ok) {
+        ok = metal_graph_upload_prompt_embeddings_hc_cpu(
+                graph.batch_cur_hc, &base_model, &base_weights,
+                &draft, 0, DSPARK_DRAFT);
+    }
+    if (ok) {
+        ok = ds4_gpu_tensor_write(graph.attn_norm, 0, current_main_x,
+                                  (uint64_t)DS4_N_EMBD * sizeof(float)) != 0;
+    }
+
+    ds4_gpu_tensor *saved_cache = graph.layer_raw_cache[0];
+    const float freq_base = layer_rope_freq_base(0);
+    const float freq_scale = layer_rope_freq_scale(0);
+    for (int stage = 0; ok && stage < DSPARK_STAGES; stage++) {
+        graph.layer_raw_cache[0] = stage_cache[stage];
+        ok = ds4_gpu_begin_commands() != 0;
+        if (ok) ok = metal_graph_matmul_plain_tensor(
+                graph.kv_raw, &support_model, dspark.stage[stage].attn_kv,
+                DS4_N_EMBD, DS4_N_HEAD_DIM, graph.attn_norm, 1);
+        if (ok) ok = ds4_gpu_rms_norm_weight_tensor(graph.kv, graph.kv_raw,
+                                                      support_model.map,
+                                                      support_model.size,
+                                                      dspark.stage[stage].attn_kv_a_norm->abs_offset,
+                                                      DS4_N_HEAD_DIM, DS4_RMS_EPS) != 0;
+        if (ok) ok = ds4_gpu_rope_tail_tensor(graph.kv, 1, DS4_N_HEAD_KV,
+                                               DS4_N_HEAD_DIM, DS4_N_ROT,
+                                               prefill_count, 0, false,
+                                               freq_base, freq_scale, 0.0f, 1.0f,
+                                               DS4_ROPE_YARN_BETA_FAST,
+                                               DS4_ROPE_YARN_BETA_SLOW) != 0;
+        if (ok && !graph.skip_raw_kv_quant)
+            ok = ds4_gpu_dsv4_fp8_kv_quantize_tensor(
+                    graph.kv, 1, DS4_N_HEAD_DIM, DS4_N_ROT) != 0;
+        if (ok) ok = ds4_gpu_store_raw_kv_tensor(stage_cache[stage], graph.kv,
+                                                  DS4_N_SWA, prefill_count,
+                                                  DS4_N_HEAD_DIM) != 0;
+        if (ok) ok = metal_graph_encode_layer_batch(&graph, &support_model,
+                                                     &dspark.stage[stage], 0,
+                                                     prefill_count + 1u,
+                                                     DSPARK_DRAFT);
+        if (ok) ok = ds4_gpu_end_commands() != 0;
+        if (ok) {
+            ok = ds4_gpu_tensor_read(
+                    graph.batch_cur_hc, 0,
+                    stage_outputs + (uint64_t)stage * DSPARK_DRAFT * DS4_N_HC * DS4_N_EMBD,
+                    (uint64_t)DSPARK_DRAFT * DS4_N_HC * DS4_N_EMBD * sizeof(float)) != 0;
+            if (ok && getenv("DS4_DSPARK_PROBE_DEBUG")) {
+                char label[32];
+                snprintf(label, sizeof(label), "dspark_stage_%d", stage);
+                print_vec_stats(label,
+                                stage_outputs + (uint64_t)stage * DSPARK_DRAFT * DS4_N_HC * DS4_N_EMBD,
+                                (uint64_t)DSPARK_DRAFT * DS4_N_HC * DS4_N_EMBD);
+            }
+        }
+    }
+    if (ok) ok = ds4_gpu_begin_commands() != 0;
+    if (ok) ok = metal_graph_encode_dspark_head_batch(
+                        &graph, &base_model, &base_weights,
+                        &support_model, &dspark, DSPARK_DRAFT);
+    if (ok) ok = ds4_gpu_end_commands() != 0;
+
+    output_ids[0] = input_token;
+    const uint16_t *markov_w1 = tensor_data(&support_model, dspark.markov_w1);
+    float markov_embed[256];
+    for (int position = 0; ok && position < DSPARK_DRAFT; position++) {
+        const uint16_t *row = markov_w1 + (uint64_t)output_ids[position] * 256u;
+        for (uint32_t i = 0; i < 256; i++) markov_embed[i] = f16_to_f32(row[i]);
+        ok = ds4_gpu_tensor_write(graph.mtp_embed, 0, markov_embed,
+                                  sizeof(markov_embed)) != 0;
+        ds4_gpu_tensor *row_logits = ds4_gpu_tensor_view(
+                graph.spec_logits,
+                (uint64_t)position * DS4_N_VOCAB * sizeof(float),
+                (uint64_t)DS4_N_VOCAB * sizeof(float));
+        if (!row_logits) ok = false;
+        if (ok) ok = ds4_gpu_begin_commands() != 0;
+        if (ok) ok = ds4_gpu_matmul_q8_0_tensor(
+                graph.logits, support_model.map, support_model.size,
+                dspark.markov_w2->abs_offset, 256, DS4_N_VOCAB,
+                graph.mtp_embed, 1) != 0;
+        if (ok) ok = ds4_gpu_add_tensor(
+                row_logits, row_logits, graph.logits, DS4_N_VOCAB) != 0;
+        if (ok) ok = ds4_gpu_argmax_tensor(
+                graph.comp_selected, row_logits, DS4_N_VOCAB) != 0;
+        if (ok) ok = ds4_gpu_end_commands() != 0;
+        if (ok) ok = ds4_gpu_tensor_read(
+                graph.comp_selected, 0, &output_ids[position + 1],
+                sizeof(output_ids[position + 1])) != 0;
+        ds4_gpu_tensor_free(row_logits);
+    }
+    graph.layer_raw_cache[0] = saved_cache;
+    if (!ok) (void)ds4_gpu_synchronize();
+    for (int stage = 0; stage < DSPARK_STAGES; stage++)
+        ds4_gpu_tensor_free(stage_cache[stage]);
+    if (graph_ready) metal_graph_free(&graph);
+    weights_free(&base_weights);
+    model_close(&support_model);
+    model_close(&base_model);
+    return ok ? 0 : 1;
+}
