+template<int nr0, typename args_t>
+void kernel_mul_mv_mxfp4_f32_impl(
+        args_t args,
+        device const char * src0,
+        device const char * src1,
+        device       char * dst,
+        threadgroup  char * shmem,
+        uint3  tgpig,
+        ushort tiisg,
+        ushort sgitg) {
+    const short NSG = FC_mul_mv_nsg;
+    threadgroup float * values = (threadgroup float *)shmem;
+    const int r0 = tgpig.x;
+    const int r1 = tgpig.y;
+    const int im = tgpig.z;
+    const int first_row = (r0 * NSG + sgitg) * nr0;
+    const uint i12 = im % args.ne12;
+    const uint i13 = im / args.ne12;
+    const uint64_t offset0 = first_row * args.nb01
+                           + (i12 / args.r2) * args.nb02
+                           + (i13 / args.r3) * args.nb03;
+    const uint64_t offset1 = r1 * args.nb11 + i12 * args.nb12 + i13 * args.nb13;
+    device const block_mxfp4 * x = (device const block_mxfp4 *)(src0 + offset0);
+    device const float * y = (device const float *)(src1 + offset1);
+    const int blocks = args.ne00 / QK_MXFP4;
+    const short ix = tiisg / 2;
+    const short it = tiisg % 2;
+    values[tiisg] = ds4_metal_mxfp4_values[tiisg % 16];
+    threadgroup_barrier(mem_flags::mem_threadgroup);
+    float sum[nr0] = {0.0f};
+    device const float * yb = y + ix * QK_MXFP4 + it * 8;
+    for (int ib = ix; ib < blocks; ib += 16) {
+        device const float4 * y4 = (device const float4 *)yb;
+        const float4 y0 = y4[0];
+        const float4 y1 = y4[4];
+        const float4 y2 = y4[1];
+        const float4 y3 = y4[5];
+        for (short row = 0; row < nr0; row++) {
+            device const block_mxfp4 & block = x[row * blocks + ib];
+            device const uchar * q = block.qs + 8 * it;
+            float4 acc = y0 * float4(values[q[0] & 15], values[q[1] & 15],
+                                     values[q[2] & 15], values[q[3] & 15]);
+            acc += y1 * float4(values[q[0] >> 4], values[q[1] >> 4],
+                               values[q[2] >> 4], values[q[3] >> 4]);
+            acc += y2 * float4(values[q[4] & 15], values[q[5] & 15],
+                               values[q[6] & 15], values[q[7] & 15]);
+            acc += y3 * float4(values[q[4] >> 4], values[q[5] >> 4],
+                               values[q[6] >> 4], values[q[7] >> 4]);
+            const float scale = as_type<float>((uint)block.e << 23);
+            sum[row] += scale * ((acc[0] + acc[1]) + (acc[2] + acc[3]));
+        }
+        yb += 16 * QK_MXFP4;
+    }
+    device float * out = (device float *)dst
+                       + (uint64_t)im * args.ne0 * args.ne1
+                       + (uint64_t)r1 * args.ne0;
+    for (int row = 0; row < nr0 && first_row + row < args.ne0; row++) {
+        const float total = simd_sum(sum[row]);
+        if (tiisg == 0) out[first_row + row] = total;
+    }
+}
