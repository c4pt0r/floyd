+kernel void kernel_dsv4_hc_mean_stage(
+        constant ds4_metal_args_dsv4_hc_mean_stage & args,
+        device const float * x,
+        device       float * dst,
+        uint gid [[thread_position_in_grid]]) {
+    const uint64_t n_elem = (uint64_t)args.n_tokens * args.n_embd;
+    if ((uint64_t)gid >= n_elem || args.n_hc == 0 ||
+        args.stage >= args.n_stages) return;
+
+    const uint32_t token = gid / args.n_embd;
+    const uint32_t dim = gid - token * args.n_embd;
+    const uint64_t input_row = (uint64_t)token * args.n_hc * args.n_embd;
+    float sum = 0.0f;
+    for (uint32_t stream = 0; stream < args.n_hc; stream++) {
+        sum += x[input_row + (uint64_t)stream * args.n_embd + dim];
+    }
+    const uint64_t output_row = (uint64_t)token * args.n_stages * args.n_embd;
+    dst[output_row + (uint64_t)args.stage * args.n_embd + dim] =
+        sum / (float)args.n_hc;
+}
