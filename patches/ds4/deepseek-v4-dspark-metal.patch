+static bool metal_graph_dspark_copy_ring(
+        ds4_gpu_tensor *cache,
+        const ds4_gpu_tensor *rows,
+        uint32_t start,
+        uint32_t n_tokens) {
+    if (!cache || !rows || n_tokens == 0 || n_tokens > DS4_N_SWA) return false;
+    const uint64_t row_bytes = (uint64_t)DS4_N_HEAD_DIM * sizeof(float);
+    const uint32_t row = start % DS4_N_SWA;
+    uint32_t first = DS4_N_SWA - row;
+    if (first > n_tokens) first = n_tokens;
+    bool ok = ds4_gpu_tensor_copy(cache,
+                                  (uint64_t)row * row_bytes,
+                                  rows,
+                                  0,
+                                  (uint64_t)first * row_bytes) != 0;
+    if (ok && first < n_tokens) {
+        ok = ds4_gpu_tensor_copy(cache,
+                                 0,
+                                 rows,
+                                 (uint64_t)first * row_bytes,
+                                 (uint64_t)(n_tokens - first) * row_bytes) != 0;
+    }
+    return ok;
+}
