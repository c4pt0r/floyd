+static bool metal_graph_capture_dspark_main_hidden(
+        ds4_gpu_graph *g,
+        uint32_t il,
+        const ds4_gpu_tensor *hc,
+        uint32_t n_tokens) {
+    if (!g->dspark_enabled || il < DS4_N_LAYER - 3u || il >= DS4_N_LAYER)
+        return true;
+    return ds4_gpu_hc_mean_stage_tensor(g->dspark_main_hidden,
+                                         hc,
+                                         DS4_N_EMBD,
+                                         DS4_N_HC,
+                                         3,
+                                         il - (DS4_N_LAYER - 3u),
+                                         n_tokens) != 0;
+}
