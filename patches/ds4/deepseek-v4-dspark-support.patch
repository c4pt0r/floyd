+static ds4_tensor *dspark_required_tensor(const ds4_model *m, uint32_t stage,
+                                          const char *suffix) {
+    char name[160];
+    snprintf(name, sizeof(name), "mtp.%u.%s", stage, suffix);
+    return required_tensor(m, name);
+}
+
+static void dspark_block_bind(ds4_layer_weights *l, const ds4_model *m,
+                              uint32_t stage) {
+    memset(l, 0, sizeof(*l));
+    l->hc_attn_fn      = dspark_required_tensor(m, stage, "hc_attn_fn.weight");
+    l->hc_attn_scale   = dspark_required_tensor(m, stage, "hc_attn_scale.weight");
+    l->hc_attn_base    = dspark_required_tensor(m, stage, "hc_attn_base.weight");
+    l->attn_norm       = dspark_required_tensor(m, stage, "attn_norm.weight");
+    l->attn_q_a        = dspark_required_tensor(m, stage, "attn_q_a.weight");
+    l->attn_q_a_norm   = dspark_required_tensor(m, stage, "attn_q_a_norm.weight");
+    l->attn_q_b        = dspark_required_tensor(m, stage, "attn_q_b.weight");
+    l->attn_kv         = dspark_required_tensor(m, stage, "attn_kv.weight");
+    l->attn_kv_a_norm  = dspark_required_tensor(m, stage, "attn_kv_a_norm.weight");
+    l->attn_sinks      = dspark_required_tensor(m, stage, "attn_sinks.weight");
+    l->attn_output_a   = dspark_required_tensor(m, stage, "attn_output_a.weight");
+    l->attn_output_b   = dspark_required_tensor(m, stage, "attn_output_b.weight");
+    l->hc_ffn_fn       = dspark_required_tensor(m, stage, "hc_ffn_fn.weight");
+    l->hc_ffn_scale    = dspark_required_tensor(m, stage, "hc_ffn_scale.weight");
+    l->hc_ffn_base     = dspark_required_tensor(m, stage, "hc_ffn_base.weight");
+    l->ffn_norm        = dspark_required_tensor(m, stage, "ffn_norm.weight");
+    l->ffn_gate_inp    = dspark_required_tensor(m, stage, "ffn_gate_inp.weight");
+    l->ffn_exp_probs_b = dspark_required_tensor(m, stage, "exp_probs_b.bias");
+    l->ffn_gate_exps   = dspark_required_tensor(m, stage, "ffn_gate_exps.weight");
+    l->ffn_up_exps     = dspark_required_tensor(m, stage, "ffn_up_exps.weight");
+    l->ffn_down_exps   = dspark_required_tensor(m, stage, "ffn_down_exps.weight");
+    l->ffn_gate_shexp  = dspark_required_tensor(m, stage, "ffn_gate_shexp.weight");
+    l->ffn_up_shexp    = dspark_required_tensor(m, stage, "ffn_up_shexp.weight");
+    l->ffn_down_shexp  = dspark_required_tensor(m, stage, "ffn_down_shexp.weight");
+}
+
+static void dspark_weights_bind(ds4_dspark_weights *w, const ds4_model *m) {
+    memset(w, 0, sizeof(*w));
+    w->main_proj = required_tensor(m, "mtp.0.main_proj.weight");
+    w->main_norm = required_tensor(m, "mtp.0.main_norm.weight");
+    for (uint32_t stage = 0; stage < 3; stage++)
+        dspark_block_bind(&w->stage[stage], m, stage);
+    w->hc_head_base = required_tensor(m, "mtp.2.hc_head_base.weight");
+    w->hc_head_fn = required_tensor(m, "mtp.2.hc_head_fn.weight");
+    w->hc_head_scale = required_tensor(m, "mtp.2.hc_head_scale.weight");
+    w->norm = required_tensor(m, "mtp.2.norm.weight");
+    w->markov_w1 = required_tensor(m, "mtp.2.markov_head.markov_w1.weight");
+    w->markov_w2 = required_tensor(m, "mtp.2.markov_head.markov_w2.weight");
+    w->confidence_proj = required_tensor(m, "mtp.2.confidence_head.proj.weight");
+    dspark_weights_validate_layout(w);
+}
+
+int ds4_dspark_support_validate(const char *path, int *stage_count) {
+    if (!path || !path[0]) return 1;
+    ds4_model model;
+    memset(&model, 0, sizeof(model));
+    model.fd = -1;
+    model_open(&model, path, false, true);
+    uint32_t stages = 0;
+    if (!model_get_u32(&model, "deepseek4.dspark_stage_count", &stages) || stages != 3) {
+        model_close(&model);
+        return 1;
+    }
+    ds4_dspark_weights weights;
+    dspark_weights_bind(&weights, &model);
+    model_close(&model);
+    if (stage_count) *stage_count = (int)stages;
+    return 0;
+}
+
 static void weights_free(ds4_weights *w) {
     memset(w, 0, sizeof(*w));
 }
