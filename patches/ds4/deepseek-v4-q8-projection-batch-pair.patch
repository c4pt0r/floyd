 }

+template<short NR1>
+void kernel_mul_mv_q8_0_f32_pair_exact_rows_impl(
+        constant ds4_metal_args_mul_mv & args0,
+        constant ds4_metal_args_mul_mv & args1,
+        device const char * src0_0,
+        device const char * src0_1,
+        device const char * src1,
+        device       char * dst0,
+        device       char * dst1,
+        threadgroup  char * shmem,
+        uint3  tgpig,
+        ushort tiisg,
+        ushort sgitg) {
+    constexpr short NR0 = N_R0_Q8_0;
+    const int r0 = tgpig.x * NR0;
+    if (r0 < args0.ne01) {
+        kernel_mul_mv_q8_0_f32_exact_rows_impl<NR1>(
+                args0, src0_0, src1, dst0, shmem, tgpig, tiisg, sgitg);
+    }
+    if (r0 < args1.ne01) {
+        kernel_mul_mv_q8_0_f32_exact_rows_impl<NR1>(
+                args1, src0_1, src1, dst1, shmem, tgpig, tiisg, sgitg);
+    }
+}
+
+#define DS4_Q8_PAIR_EXACT_ROWS_KERNEL(NR1) \
+[[host_name("kernel_mul_mv_q8_0_f32_pair_exact_rows" #NR1)]] \
+kernel void kernel_mul_mv_q8_0_f32_pair_exact_rows##NR1( \
+        constant ds4_metal_args_mul_mv & args0, \
+        constant ds4_metal_args_mul_mv & args1, \
+        device const char * src0_0, device const char * src0_1, \
+        device const char * src1, device char * dst0, device char * dst1, \
+        threadgroup char * shmem [[threadgroup(0)]], \
+        uint3 tgpig [[threadgroup_position_in_grid]], \
+        ushort tiisg [[thread_index_in_simdgroup]], \
+        ushort sgitg [[simdgroup_index_in_threadgroup]]) { \
+    kernel_mul_mv_q8_0_f32_pair_exact_rows_impl<NR1>( \
+        args0, args1, src0_0, src0_1, src1, dst0, dst1, shmem, \
+        tgpig, tiisg, sgitg); \
+}
+
+DS4_Q8_PAIR_EXACT_ROWS_KERNEL(2)
+DS4_Q8_PAIR_EXACT_ROWS_KERNEL(3)
+DS4_Q8_PAIR_EXACT_ROWS_KERNEL(4)
+
+#undef DS4_Q8_PAIR_EXACT_ROWS_KERNEL
