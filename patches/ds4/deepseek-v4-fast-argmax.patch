+struct ds4_metal_args_dsv4_argmax {
+    uint32_t count;
+    uint32_t groups;
+};
+
+static inline bool dsv4_argmax_better(float value,
+                                      int32_t index,
+                                      float best_value,
+                                      int32_t best_index) {
+    return !isnan(value) &&
+           (value > best_value ||
+            (value == best_value && index < best_index));
+}
+
+static inline void dsv4_argmax_reduce(
+        threadgroup float *values,
+        threadgroup int32_t *indices,
+        uint tid) {
+    for (uint stride = 128; stride != 0; stride >>= 1) {
+        threadgroup_barrier(mem_flags::mem_threadgroup);
+        if (tid < stride &&
+            dsv4_argmax_better(values[tid + stride],
+                               indices[tid + stride],
+                               values[tid],
+                               indices[tid])) {
+            values[tid] = values[tid + stride];
+            indices[tid] = indices[tid + stride];
+        }
+    }
+    threadgroup_barrier(mem_flags::mem_threadgroup);
+}
+
+kernel void kernel_dsv4_argmax_partial_f32(
+        constant ds4_metal_args_dsv4_argmax &args,
+        device const float *logits,
+        device float *partial_values,
+        device int32_t *partial_indices,
+        threadgroup float *values [[threadgroup(0)]],
+        threadgroup int32_t *indices [[threadgroup(1)]],
+        uint group [[threadgroup_position_in_grid]],
+        uint tid [[thread_position_in_threadgroup]]) {
+    float best_value = -FLT_MAX;
+    int32_t best_index = INT_MAX;
+    const uint first = group * 1024u + tid;
+    const uint end = min(args.count, (group + 1u) * 1024u);
+    for (uint index = first; index < end; index += 256u) {
+        const float value = logits[index];
+        if (dsv4_argmax_better(value, int32_t(index), best_value, best_index)) {
+            best_value = value;
+            best_index = int32_t(index);
+        }
+    }
+    values[tid] = best_value;
+    indices[tid] = best_index;
+    dsv4_argmax_reduce(values, indices, tid);
+    if (tid == 0) {
+        partial_values[group] = values[0];
+        partial_indices[group] = indices[0];
+    }
+}
+
+kernel void kernel_dsv4_argmax_final_f32(
+        constant ds4_metal_args_dsv4_argmax &args,
+        device const float *partial_values,
+        device const int32_t *partial_indices,
+        device int32_t *out_index,
+        threadgroup float *values [[threadgroup(0)]],
+        threadgroup int32_t *indices [[threadgroup(1)]],
+        uint tid [[thread_position_in_threadgroup]]) {
+    float best_value = -FLT_MAX;
+    int32_t best_index = INT_MAX;
+    for (uint group = tid; group < args.groups; group += 256u) {
+        const float value = partial_values[group];
+        const int32_t index = partial_indices[group];
+        if (dsv4_argmax_better(value, index, best_value, best_index)) {
+            best_value = value;
+            best_index = index;
+        }
+    }
+    values[tid] = best_value;
+    indices[tid] = best_index;
+    dsv4_argmax_reduce(values, indices, tid);
+    if (tid == 0) out_index[0] = indices[0];
+}
