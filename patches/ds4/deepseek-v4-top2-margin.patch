+int ds4_gpu_top2_tensor(
+        ds4_gpu_tensor       *out_idx,
+        ds4_gpu_tensor       *out_margin,
+        const ds4_gpu_tensor *logits,
+        uint32_t                n_vocab) {
+    if (!g_initialized && !ds4_gpu_init()) return 0;
+    if (!out_idx || !out_margin || !logits || n_vocab < 2) return 0;
+    if (ds4_gpu_tensor_bytes(out_idx) < sizeof(int32_t) ||
+        ds4_gpu_tensor_bytes(out_margin) < sizeof(float) ||
+        ds4_gpu_tensor_bytes(logits) < (uint64_t)n_vocab * sizeof(float)) {
+        fprintf(stderr, "ds4: Metal graph top2 received undersized buffers\n");
+        return 0;
+    }
+    if (!g_dsv4_top2_partial_pipeline || !g_dsv4_top2_final_pipeline) return 0;
 
+    @autoreleasepool {
+        enum { TOP2_THREADS = 256, TOP2_ITEMS_PER_GROUP = 1024 };
+        const uint32_t groups =
+            (n_vocab + TOP2_ITEMS_PER_GROUP - 1u) / TOP2_ITEMS_PER_GROUP;
+        const NSUInteger segment_bytes =
+            (((NSUInteger)groups * sizeof(float)) + 15u) & ~(NSUInteger)15u;
+        if (groups == 0 ||
+            !ds4_gpu_ensure_scratch_buffer(&g_fast_argmax_buffer,
+                                           &g_fast_argmax_bytes,
+                                           4u * segment_bytes,
+                                           "ds4_fast_argmax")) {
+            return 0;
+        }
+
+        id<MTLBuffer> logitsbuf = ds4_gpu_tensor_buffer(logits);
+        id<MTLBuffer> outbuf = ds4_gpu_tensor_buffer(out_idx);
+        id<MTLBuffer> marginbuf = ds4_gpu_tensor_buffer(out_margin);
+        if (!logitsbuf || !outbuf || !marginbuf) return 0;
+
+        ds4_gpu_dsv4_argmax_args args = {
+            .count = n_vocab,
+            .groups = groups,
+        };
+        int owned = 0;
+        id<MTLCommandBuffer> cb = ds4_gpu_command_buffer(&owned);
+        if (!cb) return 0;
+
+        id<MTLComputeCommandEncoder> enc = ds4_gpu_compute_encoder(cb);
+        [enc setComputePipelineState:g_dsv4_top2_partial_pipeline];
+        [enc setBytes:&args length:sizeof(args) atIndex:0];
+        [enc setBuffer:logitsbuf offset:ds4_gpu_tensor_offset(logits) atIndex:1];
+        [enc setBuffer:g_fast_argmax_buffer offset:0 atIndex:2];
+        [enc setBuffer:g_fast_argmax_buffer offset:segment_bytes atIndex:3];
+        [enc setBuffer:g_fast_argmax_buffer offset:2u * segment_bytes atIndex:4];
+        [enc setBuffer:g_fast_argmax_buffer offset:3u * segment_bytes atIndex:5];
+        for (NSUInteger i = 0; i < 4; i++) {
+            [enc setThreadgroupMemoryLength:TOP2_THREADS * sizeof(float) atIndex:i];
+        }
+        [enc dispatchThreadgroups:MTLSizeMake(groups, 1, 1)
+             threadsPerThreadgroup:MTLSizeMake(TOP2_THREADS, 1, 1)];
+        ds4_gpu_end_compute_encoder(cb, enc);
+
+        enc = ds4_gpu_compute_encoder(cb);
+        [enc setComputePipelineState:g_dsv4_top2_final_pipeline];
+        [enc setBytes:&args length:sizeof(args) atIndex:0];
+        [enc setBuffer:g_fast_argmax_buffer offset:0 atIndex:1];
+        [enc setBuffer:g_fast_argmax_buffer offset:segment_bytes atIndex:2];
+        [enc setBuffer:g_fast_argmax_buffer offset:2u * segment_bytes atIndex:3];
+        [enc setBuffer:g_fast_argmax_buffer offset:3u * segment_bytes atIndex:4];
+        [enc setBuffer:outbuf offset:ds4_gpu_tensor_offset(out_idx) atIndex:5];
+        [enc setBuffer:marginbuf offset:ds4_gpu_tensor_offset(out_margin) atIndex:6];
+        for (NSUInteger i = 0; i < 4; i++) {
+            [enc setThreadgroupMemoryLength:TOP2_THREADS * sizeof(float) atIndex:i];
+        }
+        [enc dispatchThreadgroups:MTLSizeMake(1, 1, 1)
+             threadsPerThreadgroup:MTLSizeMake(TOP2_THREADS, 1, 1)];
+        ds4_gpu_end_compute_encoder(cb, enc);
+
+        if (!ds4_gpu_finish_command_buffer(cb, owned, "vocabulary top2")) return 0;
+        g_fast_argmax_calls++;
+    }
+    return 1;
+}
