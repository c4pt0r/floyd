+
+struct dsv4_top2_pair {
+    float best_value;
+    float second_value;
+    int32_t best_index;
+    int32_t second_index;
+};
+
+static inline dsv4_top2_pair dsv4_top2_insert(
+        dsv4_top2_pair pair,
+        float value,
+        int32_t index) {
+    if (isnan(value) || index == pair.best_index ||
+        index == pair.second_index) return pair;
+    if (dsv4_argmax_better(value, index,
+                           pair.best_value, pair.best_index)) {
+        pair.second_value = pair.best_value;
+        pair.second_index = pair.best_index;
+        pair.best_value = value;
+        pair.best_index = index;
+    } else if (dsv4_argmax_better(value, index,
+                                  pair.second_value, pair.second_index)) {
+        pair.second_value = value;
+        pair.second_index = index;
+    }
+    return pair;
+}
+
+static inline void dsv4_top2_reduce(
+        threadgroup float *best_values,
+        threadgroup float *second_values,
+        threadgroup int32_t *best_indices,
+        threadgroup int32_t *second_indices,
+        uint tid) {
+    for (uint stride = 128; stride != 0; stride >>= 1) {
+        threadgroup_barrier(mem_flags::mem_threadgroup);
+        if (tid < stride) {
+            dsv4_top2_pair pair = {
+                best_values[tid], second_values[tid],
+                best_indices[tid], second_indices[tid],
+            };
+            pair = dsv4_top2_insert(pair, best_values[tid + stride],
+                                    best_indices[tid + stride]);
+            pair = dsv4_top2_insert(pair, second_values[tid + stride],
+                                    second_indices[tid + stride]);
+            best_values[tid] = pair.best_value;
+            second_values[tid] = pair.second_value;
+            best_indices[tid] = pair.best_index;
+            second_indices[tid] = pair.second_index;
+        }
+    }
+    threadgroup_barrier(mem_flags::mem_threadgroup);
+}
+
+kernel void kernel_dsv4_top2_partial_f32(
+        constant ds4_metal_args_dsv4_argmax &args,
+        device const float *logits,
+        device float *partial_best_values,
+        device float *partial_second_values,
+        device int32_t *partial_best_indices,
+        device int32_t *partial_second_indices,
+        threadgroup float *best_values [[threadgroup(0)]],
+        threadgroup float *second_values [[threadgroup(1)]],
+        threadgroup int32_t *best_indices [[threadgroup(2)]],
+        threadgroup int32_t *second_indices [[threadgroup(3)]],
+        uint group [[threadgroup_position_in_grid]],
+        uint tid [[thread_position_in_threadgroup]]) {
+    dsv4_top2_pair pair = {-FLT_MAX, -FLT_MAX, INT_MAX, INT_MAX};
+    const uint first = group * 1024u + tid;
+    const uint end = min(args.count, (group + 1u) * 1024u);
+    for (uint index = first; index < end; index += 256u) {
+        pair = dsv4_top2_insert(pair, logits[index], int32_t(index));
+    }
+    best_values[tid] = pair.best_value;
+    second_values[tid] = pair.second_value;
+    best_indices[tid] = pair.best_index;
+    second_indices[tid] = pair.second_index;
+    dsv4_top2_reduce(best_values, second_values,
+                     best_indices, second_indices, tid);
+    if (tid == 0) {
+        partial_best_values[group] = best_values[0];
+        partial_second_values[group] = second_values[0];
+        partial_best_indices[group] = best_indices[0];
+        partial_second_indices[group] = second_indices[0];
+    }
+}
+
+kernel void kernel_dsv4_top2_final_f32(
+        constant ds4_metal_args_dsv4_argmax &args,
+        device const float *partial_best_values,
+        device const float *partial_second_values,
+        device const int32_t *partial_best_indices,
+        device const int32_t *partial_second_indices,
+        device int32_t *out_index,
+        device float *out_margin,
+        threadgroup float *best_values [[threadgroup(0)]],
+        threadgroup float *second_values [[threadgroup(1)]],
+        threadgroup int32_t *best_indices [[threadgroup(2)]],
+        threadgroup int32_t *second_indices [[threadgroup(3)]],
+        uint tid [[thread_position_in_threadgroup]]) {
+    dsv4_top2_pair pair = {-FLT_MAX, -FLT_MAX, INT_MAX, INT_MAX};
+    for (uint group = tid; group < args.groups; group += 256u) {
+        pair = dsv4_top2_insert(pair, partial_best_values[group],
+                                partial_best_indices[group]);
+        pair = dsv4_top2_insert(pair, partial_second_values[group],
+                                partial_second_indices[group]);
+    }
+    best_values[tid] = pair.best_value;
+    second_values[tid] = pair.second_value;
+    best_indices[tid] = pair.best_index;
+    second_indices[tid] = pair.second_index;
+    dsv4_top2_reduce(best_values, second_values,
+                     best_indices, second_indices, tid);
+    if (tid == 0) {
+        out_index[0] = best_indices[0];
+        out_margin[0] = best_values[0] - second_values[0];
+    }
 }
 
