+int ds4_gpu_matmul_q4_k_tensor(
+        ds4_gpu_tensor       *out,
+        const void             *model_map,
+        uint64_t                model_size,
+        uint64_t                weight_offset,
+        uint64_t                in_dim,
+        uint64_t                out_dim,
+        const ds4_gpu_tensor *x,
+        uint64_t                n_tok) {
+    if (!g_initialized && !ds4_gpu_init()) return 0;
+    if (!out || !model_map || !x || n_tok == 0 || n_tok > UINT32_MAX ||
+        in_dim == 0 || (in_dim % 256u) != 0 ||
+        in_dim > UINT32_MAX || out_dim == 0 || out_dim > UINT32_MAX) {
+        return 0;
+    }
+
+    @autoreleasepool {
+        id<MTLBuffer> xbuf = ds4_gpu_tensor_buffer(x);
+        id<MTLBuffer> outbuf = ds4_gpu_tensor_buffer(out);
+        const uint64_t x_bytes = n_tok * in_dim * sizeof(float);
+        const uint64_t out_bytes = n_tok * out_dim * sizeof(float);
+        const uint64_t row_bytes = (in_dim / 256u) * 144u;
+        if (out_dim > UINT64_MAX / row_bytes) return 0;
+        const uint64_t weight_bytes = out_dim * row_bytes;
+        if (!xbuf || !outbuf ||
+            ds4_gpu_tensor_bytes(x) < x_bytes ||
+            ds4_gpu_tensor_bytes(out) < out_bytes ||
+            weight_offset > model_size ||
+            weight_bytes > model_size - weight_offset) {
+            return 0;
+        }
+
+        uint64_t inner_offset = 0;
+        id<MTLBuffer> wbuf = ds4_gpu_wrap_model_range(
+            model_map, model_size, weight_offset, weight_bytes,
+            &inner_offset);
+        if (!wbuf || !g_moe_mul_mv_id_q4_k_pipeline) return 0;
+
+        int32_t ids_stack[256] = {0};
+        int32_t *ids = ids_stack;
+        if (n_tok > (uint64_t)(sizeof(ids_stack) / sizeof(ids_stack[0]))) {
+            ids = calloc((size_t)n_tok, sizeof(*ids));
+            if (!ids) return 0;
+        }
+        const NSUInteger ids_bytes = (NSUInteger)n_tok * sizeof(*ids);
+        id<MTLBuffer> idsbuf = nil;
+        if (ids_bytes > 4096u) {
+            idsbuf = ds4_gpu_new_transient_buffer(ids_bytes, "dense_q4_ids");
+            if (!idsbuf) {
+                if (ids != ids_stack) free(ids);
+                return 0;
+            }
+            memcpy([idsbuf contents], ids, ids_bytes);
+        }
+
+        ds4_gpu_mul_mv_id_args args = ds4_gpu_make_mul_mv_id_args(
+            (uint32_t)in_dim, (uint32_t)out_dim, 1,
+            row_bytes, weight_bytes, 1, 1, (uint32_t)n_tok, 2);
+        int owned = 0;
+        id<MTLCommandBuffer> cb = ds4_gpu_command_buffer(&owned);
+        if (!cb) {
+            if (ids != ids_stack) free(ids);
+            return 0;
+        }
+        id<MTLComputeCommandEncoder> enc = ds4_gpu_compute_encoder(cb);
+        [enc setComputePipelineState:g_moe_mul_mv_id_q4_k_pipeline];
+        [enc setBytes:&args length:sizeof(args) atIndex:0];
+        [enc setBuffer:wbuf offset:(NSUInteger)inner_offset atIndex:1];
+        [enc setBuffer:xbuf offset:ds4_gpu_tensor_offset(x) atIndex:2];
+        [enc setBuffer:outbuf offset:ds4_gpu_tensor_offset(out) atIndex:3];
+        if (idsbuf) {
+            [enc setBuffer:idsbuf offset:0 atIndex:4];
+        } else {
+            [enc setBytes:ids length:ids_bytes atIndex:4];
+        }
+        [enc dispatchThreadgroups:MTLSizeMake(
+                 ((NSUInteger)out_dim + 3u) / 4u, 1, (NSUInteger)n_tok)
+             threadsPerThreadgroup:MTLSizeMake(32, 2, 1)];
+        ds4_gpu_end_compute_encoder(cb, enc);
+        if (ids != ids_stack) free(ids);
+        if (!ds4_gpu_finish_command_buffer(cb, owned, "dense Q4_K matvec")) {
+            return 0;
+        }
+    }
+    return 1;
+}
