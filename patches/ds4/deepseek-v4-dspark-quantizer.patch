diff --git a/gguf-tools/quants.c b/gguf-tools/quants.c
index 4e7ce5b..7f8e86e 100644
--- a/gguf-tools/quants.c
+++ b/gguf-tools/quants.c
@@ -23,6 +23,32 @@

 static pthread_mutex_t ds4q_init_mutex = PTHREAD_MUTEX_INITIALIZER;

+bool ds4q_deepseek_fp4_to_mxfp4(uint8_t *dst, const uint8_t *packed,
+                                const uint8_t *scales, int64_t nrows,
+                                int64_t ncols) {
+    if (!dst || !packed || !scales || nrows <= 0 || ncols <= 0 || ncols % 32)
+        return false;
+    const int64_t blocks_per_row = ncols / 32;
+    for (int64_t row = 0; row < nrows; row++) {
+        const uint8_t *src_row = packed + row * (ncols / 2);
+        const uint8_t *scale_row = scales + row * blocks_per_row;
+        uint8_t *dst_row = dst + row * blocks_per_row * 17;
+        for (int64_t block = 0; block < blocks_per_row; block++) {
+            const uint8_t *src = src_row + block * 16;
+            uint8_t *out = dst_row + block * 17;
+            out[0] = scale_row[block];
+            for (int i = 0; i < 16; i++) {
+                uint8_t low_source = src[i / 2];
+                uint8_t high_source = src[8 + i / 2];
+                uint8_t low = (i & 1) ? low_source >> 4 : low_source & 15;
+                uint8_t high = (i & 1) ? high_source >> 4 : high_source & 15;
+                out[1 + i] = (uint8_t)(low | (high << 4));
+            }
+        }
+    }
+    return true;
+}
