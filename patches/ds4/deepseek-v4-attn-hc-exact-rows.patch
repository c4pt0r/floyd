+template<short NR1>
+void kernel_dsv4_q8_hc_expand4_q8_0_exact_rows_impl(
+        constant ds4_metal_args_mul_mv          & mv,
+        constant ds4_metal_args_dsv4_hc_expand & hc,
+        device  const char * weight,
+        device  const char * input,
+        device        char * block_out,
+        device  const char * residual,
+        device  const char * post,
+        device  const char * comb,
+        device        char * dst,
+        threadgroup   char * shmem,
+        uint3  tgpig,
+        ushort tiisg,
+        ushort sgitg) {
+    if (hc.n_hc != 4 || hc.n_tokens != NR1) return;
+
+    const short NSG = FC_mul_mv_nsg;
+    constexpr short NW = N_SIMDWIDTH;
+    constexpr short NQ = 8;
+    constexpr short NR0 = N_R0_Q8_0;
+    const int nb = mv.ne00 / QK8_0;
+    const int row0 = tgpig.x * NR0;
+    const short ix = tiisg / (NW / NQ);
+    const short il = tiisg % (NW / NQ);
+    const int ib0 = sgitg * NQ + ix;
+
+    device const block_q8_0 *ax[NR0];
+    FOR_UNROLL(short row = 0; row < NR0; ++row) {
+        const uint64_t off0 = (uint64_t)(row0 + row) * mv.nb01;
+        ax[row] = (device const block_q8_0 *)(weight + off0);
+    }
+
+    device const float *yb[NR1];
+    FOR_UNROLL(short token = 0; token < NR1; ++token) {
+        device const float *y =
+            (device const float *)(input + (uint64_t)token * mv.nb11);
+        yb[token] = y + ib0 * QK8_0 + il * NQ;
+    }
+    float sumf[NR1][NR0] = {{0.0f}};
+    for (int ib = ib0; ib < nb; ib += NSG * NQ) {
+        FOR_UNROLL(short token = 0; token < NR1; ++token) {
+            float yl[NQ];
+            FOR_UNROLL(short i = 0; i < NQ; ++i) yl[i] = yb[token][i];
+            FOR_UNROLL(short row = 0; row < NR0; ++row) {
+                device const int8_t *qs = ax[row][ib].qs + il * NQ;
+                float sumq = 0.0f;
+                FOR_UNROLL(short i = 0; i < NQ; ++i) sumq += qs[i] * yl[i];
+                sumf[token][row] += sumq * ax[row][ib].d;
+            }
+            yb[token] += NSG * NQ * QK8_0;
+        }
+    }
+
+    threadgroup float *shmem_f32[NR0];
+    FOR_UNROLL(short row = 0; row < NR0; ++row)
+        shmem_f32[row] = (threadgroup float *)shmem + NW * row;
+
+    FOR_UNROLL(short token = 0; token < NR1; ++token) {
+        FOR_UNROLL(short row = 0; row < NR0; ++row) {
+            if (sgitg == 0) shmem_f32[row][tiisg] = 0.0f;
+            sumf[token][row] = simd_sum(sumf[token][row]);
+        }
+        threadgroup_barrier(mem_flags::mem_threadgroup);
+
+        FOR_UNROLL(short row = 0; row < NR0; ++row) {
+            if (tiisg == 0) shmem_f32[row][sgitg] = sumf[token][row];
+        }
+        threadgroup_barrier(mem_flags::mem_threadgroup);
+
+        FOR_UNROLL(short row = 0; row < NR0; ++row) {
+            const int d = row0 + row;
+            if (d >= mv.ne01) continue;
+            const float block_v = simd_sum(shmem_f32[row][tiisg]);
+            if (tiisg == 0 && sgitg == 0) {
+                *((device float *)(block_out +
+                    ((uint64_t)token * mv.ne0 + d) * sizeof(float))) = block_v;
+
+                const float r0 = *((device const float *)(residual +
+                    (uint64_t)d * hc.nb_res0 + 0 * hc.nb_res1 + token * hc.nb_res2));
+                const float r1 = *((device const float *)(residual +
+                    (uint64_t)d * hc.nb_res0 + 1 * hc.nb_res1 + token * hc.nb_res2));
+                const float r2 = *((device const float *)(residual +
+                    (uint64_t)d * hc.nb_res0 + 2 * hc.nb_res1 + token * hc.nb_res2));
+                const float r3 = *((device const float *)(residual +
+                    (uint64_t)d * hc.nb_res0 + 3 * hc.nb_res1 + token * hc.nb_res2));
+
+                for (int64_t dst_hc = 0; dst_hc < 4; ++dst_hc) {
+                    float acc = block_v * *((device const float *)(post +
+                        dst_hc * hc.nb_post0 + token * hc.nb_post1));
+                    acc += *((device const float *)(comb + dst_hc * hc.nb_comb0 +
+                        0 * hc.nb_comb1 + token * hc.nb_comb2)) * r0;
+                    acc += *((device const float *)(comb + dst_hc * hc.nb_comb0 +
+                        1 * hc.nb_comb1 + token * hc.nb_comb2)) * r1;
+                    acc += *((device const float *)(comb + dst_hc * hc.nb_comb0 +
+                        2 * hc.nb_comb1 + token * hc.nb_comb2)) * r2;
+                    acc += *((device const float *)(comb + dst_hc * hc.nb_comb0 +
+                        3 * hc.nb_comb1 + token * hc.nb_comb2)) * r3;
+                    *((device float *)(dst + (uint64_t)d * hc.nb0 +
+                        dst_hc * hc.nb1 + token * hc.nb2)) = acc;
+                }
+            }
+        }
+        threadgroup_barrier(mem_flags::mem_threadgroup);
+    }
+}
+
+#define DS4_ATTN_HC_EXACT_ROWS_KERNEL(NR1) \
+[[host_name("kernel_dsv4_q8_hc_expand4_q8_0_rows" #NR1)]] \
+kernel void kernel_dsv4_q8_hc_expand4_q8_0_rows##NR1( \
+        constant ds4_metal_args_mul_mv & mv, \
+        constant ds4_metal_args_dsv4_hc_expand & hc, \
+        device const char * weight, device const char * input, \
+        device char * block_out, device const char * residual, \
+        device const char * post, device const char * comb, device char * dst, \
+        threadgroup char * shmem [[threadgroup(0)]], \
+        uint3 tgpig [[threadgroup_position_in_grid]], \
+        ushort tiisg [[thread_index_in_simdgroup]], \
+        ushort sgitg [[simdgroup_index_in_threadgroup]]) { \
+    kernel_dsv4_q8_hc_expand4_q8_0_exact_rows_impl<NR1>( \
+        mv, hc, weight, input, block_out, residual, post, comb, dst, shmem, \
+        tgpig, tiisg, sgitg); \
+}
+
+DS4_ATTN_HC_EXACT_ROWS_KERNEL(2)
+DS4_ATTN_HC_EXACT_ROWS_KERNEL(3)
+DS4_ATTN_HC_EXACT_ROWS_KERNEL(4)
+
+#undef DS4_ATTN_HC_EXACT_ROWS_KERNEL
